generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  REVIEWER
  READ_ONLY
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships           Membership[]
  documents             Document[]
  invoices              Invoice[]
  auditLogs             AuditLog[]
  outboxEvents          OutboxEvent[]
  integrationSyncEvents IntegrationSyncEvent[]
}

model Membership {
  id        String   @id @default(uuid())
  userId    String
  tenantId  String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@index([tenantId])
  @@index([userId])
}

enum DocumentStatus {
  UPLOADED
  PROCESSING
  EXTRACTED
  VALIDATION_FAILED
  READY_FOR_REVIEW
  FAILED
}

enum InvoiceStatus {
  DRAFT
  APPROVED
  REJECTED
  SYNCING
  SYNCED
  SYNC_FAILED
}

model Document {
  id          String         @id @default(uuid())
  tenantId    String
  uploadedBy  String
  filename    String
  content     String
  status      DocumentStatus @default(UPLOADED)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  extraction DocumentExtraction?
  invoices   Invoice[]

  @@index([tenantId, status, createdAt])
}

model DocumentExtraction {
  id               String   @id @default(uuid())
  documentId       String   @unique
  extractedJson    Json
  confidenceJson   Json
  validationErrors Json?
  createdAt        DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String        @id @default(uuid())
  tenantId      String
  documentId    String?
  invoiceNumber String
  supplierName  String
  invoiceDate   DateTime
  currency      String
  grossAmount   Decimal
  status        InvoiceStatus @default(DRAFT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)

  integrationSyncEvents IntegrationSyncEvent[]

  @@index([tenantId, status, createdAt])
  @@unique([tenantId, invoiceNumber, supplierName])
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

enum SyncStatus {
  PENDING
  SUCCESS
  FAILED
}

model AuditLog {
  id          String   @id @default(uuid())
  tenantId    String
  actorUserId String?
  entityType  String
  entityId    String
  action      String
  metadata    Json?
  createdAt   DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
}

model OutboxEvent {
  id          String       @id @default(uuid())
  tenantId    String
  eventType   String
  payload     Json
  status      OutboxStatus @default(PENDING)
  attempts    Int          @default(0)
  createdAt   DateTime     @default(now())
  processedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, createdAt])
}

model IntegrationSyncEvent {
  id              String     @id @default(uuid())
  tenantId        String
  invoiceId       String
  externalSystem  String
  status          SyncStatus
  requestPayload  Json?
  responsePayload Json?
  errorMessage    String?
  idempotencyKey  String
  createdAt       DateTime   @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([tenantId, externalSystem, idempotencyKey])
  @@index([tenantId, status, createdAt])
}